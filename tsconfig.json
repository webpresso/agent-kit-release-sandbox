{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2024",
    "lib": [
      "ES2024"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": [
      "node",
      "bun"
    ],
    "outDir": "./dist",
    "paths": {
      "#e2e": [
        "./src/e2e/index.ts"
      ],
      "#e2e/*": [
        "./src/e2e/*.ts"
      ],
      "#test": [
        "./src/test/index.ts"
      ],
      "#symlinker": [
        "./src/symlinker/index.ts"
      ],
      "#paths/*": [
        "./src/paths/*"
      ],
      "#cli/auto-update/*": [
        "./src/cli/auto-update/*"
      ],
      "#db/*": [
        "./src/blueprint/db/*"
      ],
      "#cli/*": [
        "./src/cli/*"
      ],
      "#dev/*": [
        "./src/dev/*.ts"
      ],
      "#audit/*": [
        "./src/audit/*.ts"
      ],
      "#docs-linter/*": [
        "./src/docs-linter/*.ts"
      ],
      "#config/tsconfig/*": [
        "./src/config/tsconfig/*"
      ],
      "#config/vitest/*": [
        "./src/config/vitest/*.ts"
      ],
      "#config/stryker/*": [
        "./src/config/stryker/*.ts"
      ],
      "#config/oxlint/*": [
        "./src/config/oxlint/*.ts"
      ],
      "#config/workers-test/*": [
        "./src/config/workers-test/*.ts"
      ],
      "#config/docs-lint/*": [
        "./src/config/docs-lint/*"
      ],
      "#config/launch/*": [
        "./src/config/launch/*.ts"
      ],
      "#config/test-preset/*": [
        "./src/config/test-preset/*.ts"
      ],
      "#config/e2e-preset/*": [
        "./src/config/e2e-preset/*.ts"
      ],
      "#ci/*": [
        "./src/ci/*"
      ],
      "#hooks/*": [
        "./src/hooks/*"
      ],
      "#secret-gate/*": [
        "./src/secret-gate/*"
      ],
      "#mcp/*": [
        "./src/mcp/*"
      ],
      "#content/*": [
        "./src/content/*"
      ],
      "#output-transforms/*": [
        "./src/output-transforms/*"
      ],
      "#lint/*": [
        "./src/lint/*"
      ],
      "#format/*": [
        "./src/format/*"
      ],
      "#symlinker/*": [
        "./src/symlinker/*"
      ],
      "#compiler/*": [
        "./src/compiler/*.ts"
      ],
      "#codex/app-server/client": [
        "./src/codex/app-server/client.ts"
      ],
      "#codex/app-server/client.js": [
        "./src/codex/app-server/client.ts"
      ],
      "#codex/app-server/types": [
        "./src/codex/app-server/types.ts"
      ],
      "#codex/app-server/types.js": [
        "./src/codex/app-server/types.ts"
      ],
      "#quality-engine": [
        "./src/quality-engine/index.ts"
      ],
      "#quality-engine/*": [
        "./src/quality-engine/*.ts"
      ],
      "#ai-memory/checkpoint/*": [
        "./src/ai-memory/checkpoint/*.ts"
      ],
      "#ai-memory/facts/*": [
        "./src/ai-memory/facts/*.ts"
      ],
      "#ai-memory/hierarchy/*": [
        "./src/ai-memory/hierarchy/*.ts"
      ],
      "#blueprint/sync/types.js": [
        "./src/blueprint/sync/types.ts"
      ],
      "#blueprint/sync/auth.js": [
        "./src/blueprint/sync/auth.ts"
      ],
      "#blueprint/sync/client.js": [
        "./src/blueprint/sync/client.ts"
      ],
      "#projects.js": [
        "./src/blueprint/projects.ts"
      ],
      "#next-action.js": [
        "./src/blueprint/next-action.ts"
      ],
      "#*.js": [
        "./src/blueprint/*.ts"
      ],
      "#*": [
        "./src/blueprint/*"
      ]
    },
    "rootDir": "./src"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.integration.test.ts"
  ]
}
