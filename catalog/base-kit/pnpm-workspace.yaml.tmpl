packages:
  - packages/*
  - apps/*

catalog:
  # TypeScript compiler and type infrastructure
  typescript: ^5.9.3

  # Testing
  vitest: ^4.1.4
  '@vitest/coverage-v8': ^4.1.4

  # Linting and formatting
  eslint: ^9.0.0
  prettier: ^3.0.0

  # Build tooling
  vite: ^8.0.0
  tsup: ^8.0.0

  # Node types
  '@types/node': ^22.0.0

  # Commit tooling
  husky: ^9.0.0
  '@commitlint/cli': ^19.0.0
  '@commitlint/config-conventional': ^19.0.0

  # Secret linting
  secretlint: ^9.0.0
  '@secretlint/secretlint-rule-preset-recommend': ^9.0.0

  # AI SDK
  '@anthropic-ai/sdk': ^0.71.2

  # HTTP
  zod: ^4.3.6

  # Utilities
  yaml: ^2.8.1
  dotenv: ^16.0.0

  # React (if applicable)
  react: ^19.0.0
  react-dom: ^19.0.0
  '@types/react': ^19.0.0
  '@types/react-dom': ^19.0.0

cleanupUnusedCatalogs: true
