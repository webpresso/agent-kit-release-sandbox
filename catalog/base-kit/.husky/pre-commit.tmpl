#!/usr/bin/env sh
set -eu
# Prefer local node_modules/.bin/wp; fall back to global wp for repos
# that rely on the global install (no local webpresso devDep).
WP="$(git rev-parse --show-toplevel)/node_modules/.bin/wp"
[ -x "$WP" ] || WP=wp
bun scripts/check-no-dev-vars.ts
"$WP" audit absolute-path-policy --root .
bun scripts/audit-secret-provider-quarantine.ts
"$WP" audit guardrails
