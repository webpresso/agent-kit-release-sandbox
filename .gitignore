.agents/
.gemini/
.cursor/
.windsurf/
.omx/
.omc/
.codex/
.opencode/
# .claude/ is partially tracked:
#   settings.json, hooks/, rules/ — committed so worktrees inherit them
#   worktrees/ and skills/ — gitignored (runtime / user-global)
.claude/worktrees/
.claude/skills/
.claude/scheduled_tasks.lock

# tshy build cache — regenerated on every build
.tshy/

# Generated reports (mutation, coverage summaries, audit dumps)
reports/

# Stryker scratch — written next to stryker.config when running locally
stryker-setup-*.js

# Test sandbox: __fixtures__/fake-home/ exposes a fake $HOME for test runs.
# Anything under .vite-plus/ is a runtime install with absolute symlinks
# that won't transfer between machines — keep tracked fixtures elsewhere.
__fixtures__/fake-home/.vite-plus/


.gstack/

